DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=ctp_platanar
DB_DIALECT=mysql
PORT=5000
NODE_ENV=development
JWT_SECRET=your_secret_key_here

# Configuración SMTP para enviar notificaciones de asistencia reales:
# SMTP_HOST=smtp.tuservidor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu_usuario
# SMTP_PASS=tu_contraseña
# SMTP_FROM="CTP Platanar <no-reply@ctp-platanar.edu>"
# SMTP_REJECT_UNAUTHORIZED=false   # Solo si tu servidor SMTP usa certificado autofirmado
# SMTP_SERVICE=gmail              # Opcional, útil para Gmail u otros servicios compatibles
# Ejemplo con Gmail (requiere app password y TLS):
# SMTP_SERVICE=gmail
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASS=tu_app_password
# SMTP_FROM="CTP Platanar <no-reply@ctp-platanar.edu>"

# Para despliegues en la nube puedes usar DATABASE_URL en lugar de DB_HOST/DB_USER/DB_PASSWORD/DB_NAME:
# DATABASE_URL=mysql://user:password@host:3306/ctp_platanar
# DATABASE_URL=postgres://user:password@host:5432/ctp_platanar
# Si tu proveedor requiere SSL:
# DB_SSL=true
