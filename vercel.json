{
  "version": 2,
  "installCommand": "npm run install-deps",
  "buildCommand": "npm run build-frontend",
  "builds": [
    {
      "src": "ctp-platanar-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "ctp-platanar-frontend/build/index.html"
    }
  ]
}
